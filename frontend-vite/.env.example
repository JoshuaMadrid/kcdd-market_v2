# ==============================================================================
# Frontend (Vite) — environment variables
# ==============================================================================
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored.
#
# Vite env vars MUST be prefixed with VITE_ to reach the browser bundle.
# See: https://vitejs.dev/guide/env-and-mode.html

# ------------------------------------------------------------------------------
# Clerk — authentication (Google / LinkedIn / Microsoft via Clerk dashboard)
# ------------------------------------------------------------------------------
# Dashboard: https://dashboard.clerk.com → app → API Keys → Publishable keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ------------------------------------------------------------------------------
# Supabase — database (publishable/anon key; safe to expose; RLS-enforced)
# ------------------------------------------------------------------------------
VITE_SUPABASE_URL=http://localhost:54321
# Current code (config/index.ts:16) expects VITE_SUPABASE_ANON_KEY. Local Docker
# stack ships a fixed dev key; run `pnpm db:status` from backend/ to copy.
# In Supabase 2024+ this is called the "publishable key" (sb_publishable_...);
# the project still reads it under the legacy VITE_SUPABASE_ANON_KEY name.
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# ------------------------------------------------------------------------------
# Stripe — payment intents (publishable key only, never the secret)
# ------------------------------------------------------------------------------
# Dashboard: https://dashboard.stripe.com → Developers → API keys → Publishable
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ------------------------------------------------------------------------------
# Backend API
# ------------------------------------------------------------------------------
VITE_API_URL=http://localhost:4000

# ------------------------------------------------------------------------------
# App config + feature flags
# ------------------------------------------------------------------------------
VITE_APP_NAME=KC Digital Drive Market
VITE_ENVIRONMENT=development
VITE_ENABLE_PAYMENTS=true
VITE_ENABLE_REALTIME=true
VITE_ENABLE_ANALYTICS=false
