SUPABASE_URL=http://localhost:54321
SUPABASE_SECRET_KEY=sb_secret_...
CLERK_SECRET_KEY=sk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Dev only: skip Stripe Connect destination charges so donations work without each
# org having a connected Stripe account. Without this, /api/payments/create-intent
# returns 400 STRIPE_NOT_CONNECTED for any org missing stripe_account_id /
# stripe_charges_enabled=true. NEVER set in production.
STRIPE_BYPASS_CONNECT=true

PORT=4000
ALLOWED_ORIGINS=http://localhost:3000
NODE_ENV=development
